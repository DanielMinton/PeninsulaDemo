# Public — exposed to the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=https://thepeninsulapickup.com
# Cloudflare Turnstile (invisible) site key. When unset, the widget is hidden
# and server-side verification is skipped in dev (and fails closed in prod).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-only — never expose in NEXT_PUBLIC_*
# Cloudflare Turnstile secret key (paired with the site key above).
TURNSTILE_SECRET_KEY=

# Upstash Redis for /api/lead rate limiting (5/hr, 20/day per IP).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Twilio Programmable SMS for new-lead notifications.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15555555555
LEAD_NOTIFY_PHONE=+16502011543

# Resend transactional email — secondary lead notification channel.
RESEND_API_KEY=
RESEND_FROM=Peninsula Pick Ups <leads@thepeninsulapickup.com>
LEAD_NOTIFY_EMAIL=hello@thepeninsulapickup.com

# Django CRM forwarding. Falls back to NEXT_PUBLIC_API_URL/api/leads/ if unset.
LEAD_STORE_URL=
LEAD_INTERNAL_TOKEN=

# Stadia Maps key — only used at build time by `npm run build:basemap` to fetch
# Stamen Terrain tiles for the service-area map. Free key at
# https://client.stadiamaps.com/. Never sent to the browser.
STADIA_API_KEY=
